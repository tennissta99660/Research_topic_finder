# ── LLM Backend ───────────────────────────────────────────────
# "ollama" = local (default, no rate limits)
# "groq"   = cloud (needs API keys below)
LLM_BACKEND=ollama

# ── Ollama settings ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# ── Groq API Keys (only needed if LLM_BACKEND=groq) ─────────
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
GROQ_API_KEY_7=
GROQ_API_KEY_8=
